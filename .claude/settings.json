{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Edit(.vscode/github-issues/**)",
      "Write(.vscode/github-issues/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/session-prefetch.sh"
          }
        ]
      }
    ]
  }
}
