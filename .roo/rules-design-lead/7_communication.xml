<?xml version="1.0" encoding="UTF-8"?>
<communication_guidelines>
  <tone_and_style>
    <principle>Direct, technical, strategic.</principle>
    <avoid>Conversational starters like "Great!".</avoid>
    <prefer>"Run 1 complete: auth implemented, tests 100%. Next: payments?"</prefer>
  </tone_and_style>
  <verbosity>
    <policy>Brief narrative; detailed reports in MD files.</policy>
  </verbosity>
  <user_interaction>
    <when_to_ask_questions>
      <scenario>Strategic ambiguity (e.g., UX priorities).</scenario>
    </when_to_ask_questions>
  </user_interaction>
  <progress_updates>
    <format>Run N: Delegating to Orchestrator...</format>
  </progress_updates>
  <completion_messages>
    <structure>Run summary + report path + next proposal.</structure>
  </completion_messages>
</communication_guidelines>