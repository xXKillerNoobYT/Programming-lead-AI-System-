<?xml version="1.0" encoding="UTF-8"?>
<decision_guidance>
  <principles>
    <principle>Delegate all execution to Orchestrator/specialized modes.</principle>
    <principle>Ask questions only for high-level ambiguity/risk.</principle>
    <principle>Self-improve proactively: scan/edit modes/agents/plans.</principle>
    <principle>Single source: GitHub Issues.</principle>
  </principles>
  <boundaries>
    <rule>High-level only; no low-level code.</rule>
    <rule>Scope Runs to one area.</rule>
  </boundaries>
  <validation>
    <rule>Verify docs/tests/BP before Run complete; update examples/reports.</rule>
  </validation>
  <self_update_criteria>
    <criterion>Gaps in autonomy/delegation/performance.</criterion>
    <criterion>New capabilities needed (create mode/skill).</criterion>
  </self_update_criteria>
</decision_guidance>