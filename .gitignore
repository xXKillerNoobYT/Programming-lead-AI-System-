reports/cohesion/*.json

# PM2 log files — keep dir (`.gitkeep`), ignore contents (Phase 4 §A.1)
logs/*
!logs/.gitkeep

# Environment variables (never commit)
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS/editor noise
.DS_Store
Thumbs.db

