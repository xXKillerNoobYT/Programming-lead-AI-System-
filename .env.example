# DevLead MCP — Environment Variables Template (Phase 4 §C.2 / D-20260418-021)
#
# Copy this file to `.env` and fill in per-machine values before starting
# Claude Code or running `node heartbeat.js`. `.env` is git-ignored; do not
# commit it. Values here are placeholders — replace with real ones.
#
# Loaded automatically by:
#   - Node 20+ `process.loadEnvFile()` in heartbeat.js (no `dotenv` dep required)
#   - Next.js dev server in dashboard/ via built-in `.env.local` loading
#     (dashboard uses `.env.local`, NOT this file — see dashboard/README or docs)
#
# -----------------------------------------------------------------------------
# Section 1 — MCP server paths (.mcp.json uses `${VAR}` substitution)
# -----------------------------------------------------------------------------

# Absolute path to this clone. The filesystem MCP server's sandbox root.
# bash/zsh:   WORKSPACE_DIR="$(pwd)"   (from repo root)
# PowerShell: $env:WORKSPACE_DIR = (Get-Location).Path
# Plain:      WORKSPACE_DIR=/abs/path/to/Programming-lead-AI-System-
WORKSPACE_DIR=

# Absolute path to the MemPalace memory palace directory.
# Default install lives at ~/.GitHub/mempalace/palace on Windows.
# If unset, MemPalace MCP fails to start (heartbeat still works; cross-run
# memory falls back to decision-log.md + memory.md + reports/*.md).
MEMPALACE_PALACE_PATH=

# GitHub Personal Access Token for the `github` MCP (sub-issue graph, Issue/PR
# operations). Needs `repo` scope. Create at https://github.com/settings/tokens
# NEVER commit this value — `.env` is git-ignored, but double-check before any
# `git add -A` from the repo root.
GITHUB_PERSONAL_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Section 2 — Heartbeat runtime
# -----------------------------------------------------------------------------

# Tick interval in ms for `heartbeat.js --watch` mode. Default 60000 (1 min).
# Minimum 30000 per SOUL.md §Heartbeat (30-90s configurable range).
HEARTBEAT_INTERVAL_MS=60000

# MCP client connect timeout in ms. Default 30000 (Windows npx cold-start can
# exceed 10s). Raise if you see frequent "connect failed" lines in tick reports.
MCP_CONNECT_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Section 3 — Grok 4.1 Fast (hourly strategic escalation)
# -----------------------------------------------------------------------------

# API key for the hourly Grok escalation. Optional — heartbeat runs local-only
# if unset. See `Docs/Plans/Part 6 LLM Usage Strategy.md` for the local-first
# hybrid policy.
GROK_API_KEY=

# Per-day / per-month budget caps in USD for Grok escalation calls. When the
# running total (tracked in reports/budget/<YYYY-MM>.json per Phase 4 §G.1)
# crosses these thresholds, heartbeat falls back to local-LLM-only mode until
# the period rollover. Dashboard surfaces a toast at 50/80/100%.
GROK_DAILY_BUDGET_USD=1.00
GROK_MONTHLY_BUDGET_USD=20.00

# -----------------------------------------------------------------------------
# Section 4 — Logs (Phase 4 §A.5 / §D.1)
# -----------------------------------------------------------------------------

# Log level for JSONL heartbeat logs: debug | info | warn | error
LOG_LEVEL=info

# Retention in days for rotating logs/heartbeat-*.jsonl
LOG_RETENTION_DAYS=14

# -----------------------------------------------------------------------------
# Section 5 — Cohesion / CI integration
# -----------------------------------------------------------------------------

# Optional: heartbeat runs set this so each cohesion-check JSON artifact
# identifies the tick's decision. CI sets it to the PR HEAD SHA.
# COHESION_DECISION_ID=
